@page
@model TimesheetAutomation.Web.Pages.TilLedgerImportModel
@{
    ViewData["Title"] = "Import TIL Ledger";
}

<div class="container mt-4" style="max-width: 720px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Import TIL Ledger</h1>
            <div class="text-muted">Upload your latest timesheet workbook to backfill historical TIL ledger rows.</div>
        </div>
        <a asp-page="/Index" class="btn btn-outline-secondary">Back to Dashboard</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="UploadFile" class="form-label">Latest Timesheet Workbook (.xlsx)</label>
                    <input asp-for="UploadFile" class="form-control" type="file" accept=".xlsx" />
                    <span asp-validation-for="UploadFile" class="text-danger"></span>
                </div>

                <div class="alert alert-info">
                    The workbook must contain a sheet named <strong>TIL Balance</strong>. Imported rows will be stored as historical reference items and future exports will carry them forward.
                </div>

                <button type="submit" class="btn btn-primary">Import Ledger</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}