@page
@model TimesheetAutomation.Web.Pages.LogoutModel
@{
    ViewData["Title"] = "Logout";
}

<div class="container mt-5" style="max-width: 460px;">
    <div class="card shadow-sm">
        <div class="card-body text-center">
            <h1 class="h4 mb-3">Sign out</h1>
            <p class="text-muted">Are you sure you want to sign out?</p>

            <form method="post">
                <button type="submit" class="btn btn-danger">Sign out</button>
                <a asp-page="/Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>