@page
@model TimesheetAutomation.Web.Pages.EnableAuthenticatorModel
@{
    ViewData["Title"] = "Enable Authenticator";
}

<div class="container mt-5" style="max-width: 760px;">
    <div class="card shadow-sm">
        <div class="card-body">
            <h1 class="h3 mb-3">Enable authenticator app</h1>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="alert alert-success">@Model.StatusMessage</div>
            }

            @if (Model.IsAlreadyEnabled)
            {
                <div class="alert alert-success">
                    Two-factor authentication is enabled on your account.
                </div>

                <div class="alert alert-info">
                    MFA is required for this application and cannot be disabled by users.
                    If you lose access to your authenticator app, contact an administrator or use a recovery code.
                </div>

                <a asp-page="/Welcome" class="btn btn-primary">Continue</a>
                <a asp-page="/Index" class="btn btn-outline-secondary ms-2">Back to Dashboard</a>
            }
            else
            {
                <p class="text-muted">
                    Scan this QR code in Microsoft Authenticator, Google Authenticator, or another TOTP app.
                    If scanning is not available, use the manual setup key below.
                </p>

                <div class="text-center mb-4">
                    <img src="@Model.QrCodeDataUri" alt="Authenticator QR Code" class="img-fluid border rounded p-2 bg-white" style="max-width: 280px;" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Manual setup key</label>
                    <input class="form-control" value="@Model.ManualEntryKey" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Authenticator URI</label>
                    <textarea class="form-control" rows="3" readonly>@Model.AuthenticatorUri</textarea>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Code" class="form-label"></label>
                        <input asp-for="Input.Code" class="form-control" autocomplete="one-time-code" />
                        <span asp-validation-for="Input.Code" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Enable authenticator</button>
                </form>
            }
        </div>
    </div>

    @if (Model.RecoveryCodes.Count > 0)
    {
        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h2 class="h5">Recovery codes</h2>
                <p class="text-muted">Save these codes in a safe place. Each code can be used once.</p>
                <ul class="mb-0">
                    @foreach (var code in Model.RecoveryCodes)
                    {
                        <li><code>@code</code></li>
                    }
                </ul>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}