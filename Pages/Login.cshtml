@page
@model TimesheetAutomation.Web.Pages.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="container mt-5" style="max-width: 480px;">
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <h1 class="h4 mb-3">Chemwatch Timesheet</h1>
            <p class="text-muted mb-4">
                Sign in with your Chemwatch Google account.
            </p>

            <form method="post">
                <button type="submit" class="btn btn-primary w-100">
                    Sign in with Google
                </button>
            </form>
        </div>
    </div>
</div>