@page
@model TimesheetAutomation.Web.Pages.LoginWith2faModel
@{
    ViewData["Title"] = "Two-factor verification";
}

<div class="container mt-5" style="max-width: 520px;">
    <div class="card shadow-sm">
        <div class="card-body">
            <h1 class="h3 mb-3">Two-factor verification</h1>
            <p class="text-muted">Enter your 6-digit authenticator code or one recovery code.</p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Code" class="form-label"></label>
                    <input asp-for="Input.Code" class="form-control" autocomplete="one-time-code" />
                    <span asp-validation-for="Input.Code" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Input.UseRecoveryCode" class="form-check-input" />
                    <label asp-for="Input.UseRecoveryCode" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-primary w-100">Verify</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}