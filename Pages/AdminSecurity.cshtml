@page
@model TimesheetAutomation.Web.Pages.AdminSecurityModel
@{
    ViewData["Title"] = "Admin Security";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Admin Security</h1>
            <div class="text-muted">Reset passwords, reset MFA, and manage admin access for internal users.</div>
        </div>
        <a asp-page="/Index" class="btn btn-outline-secondary">Back to Dashboard</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Admin</th>
                            <th>MFA</th>
                            <th>Password Reset</th>
                            <th>MFA Reset</th>
                            <th>Admin Access</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.DisplayName</td>
                                <td>@user.Email</td>
                                <td>
                                    @if (user.IsAdmin)
                                    {
                                        <span class="badge bg-success">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">User</span>
                                    }
                                </td>
                                <td>
                                    @if (user.IsTwoFactorEnabled)
                                    {
                                        <span class="badge bg-success">Enabled</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Disabled</span>
                                    }
                                </td>
                                <td>
                                    <form method="post" asp-page-handler="ResetPassword" class="d-flex gap-2">
                                        <input type="hidden" name="TargetUserId" value="@user.Id" />
                                        <input type="password" name="NewPassword" class="form-control form-control-sm" placeholder="New password" />
                                        <button type="submit" class="btn btn-sm btn-primary">Set</button>
                                    </form>
                                </td>
                                <td>
                                    <form method="post" asp-page-handler="ResetMfa">
                                        <input type="hidden" name="TargetUserId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-warning">Disable MFA</button>
                                    </form>
                                </td>
                                <td>
                                    @if (user.IsAdmin)
                                    {
                                        <form method="post" asp-page-handler="RemoveAdmin">
                                            <input type="hidden" name="TargetUserId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove Admin</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="GrantAdmin">
                                            <input type="hidden" name="TargetUserId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success">Make Admin</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>