@page
@model TimesheetAutomation.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Dashboard</h1>
            <div class="text-muted">Welcome, @Model.DisplayName</div>
        </div>
        <a asp-page="/Logout" class="btn btn-outline-secondary">Sign out</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Today</h2>
                    <p class="text-muted">Open today’s entry page.</p>
                    <a asp-page="/Entry" class="btn btn-primary">Open today</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Fortnight Summary</h2>
                    <p class="text-muted">Review and quick-edit the current fortnight.</p>
                    <a asp-page="/Summary" class="btn btn-primary">Open summary</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Exports</h2>
                    <p class="text-muted">Generate and download the current fortnight export.</p>
                    <a asp-page="/Exports" class="btn btn-primary">Open exports</a>
                </div>
            </div>
        </div>
    </div>
</div>